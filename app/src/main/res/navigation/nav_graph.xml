<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.slots.app.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_tasks"
            app:destination="@id/tasksFragment" />
        <action
            android:id="@+id/action_dashboard_to_budget"
            app:destination="@id/budgetFragment" />
        <action
            android:id="@+id/action_dashboard_to_debt"
            app:destination="@id/debtFragment" />
        <action
            android:id="@+id/action_dashboard_to_chatbot"
            app:destination="@id/chatbotFragment" />
    </fragment>

    <fragment
        android:id="@+id/tasksFragment"
        android:name="com.slots.app.ui.tasks.TasksFragment"
        android:label="Tasks"
        tools:layout="@layout/fragment_tasks">
        <action
            android:id="@+id/action_tasks_to_addEditTask"
            app:destination="@id/addEditTaskFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditTaskFragment"
        android:name="com.slots.app.ui.tasks.AddEditTaskFragment"
        android:label="Task"
        tools:layout="@layout/fragment_add_edit_task">
        <argument
            android:name="taskId"
            app:argType="long"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/budgetFragment"
        android:name="com.slots.app.ui.budget.BudgetFragment"
        android:label="Budget"
        tools:layout="@layout/fragment_budget">
        <action
            android:id="@+id/action_budget_to_addTransaction"
            app:destination="@id/addTransactionFragment" />
    </fragment>

    <fragment
        android:id="@+id/addTransactionFragment"
        android:name="com.slots.app.ui.budget.AddTransactionFragment"
        android:label="Add Transaction"
        tools:layout="@layout/fragment_add_transaction" />

    <fragment
        android:id="@+id/debtFragment"
        android:name="com.slots.app.ui.budget.DebtFragment"
        android:label="Debts"
        tools:layout="@layout/fragment_debt" />

    <fragment
        android:id="@+id/chatbotFragment"
        android:name="com.slots.app.ui.chatbot.ChatbotFragment"
        android:label="AI Chat"
        tools:layout="@layout/fragment_chatbot" />

</navigation>
